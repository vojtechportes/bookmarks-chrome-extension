{
  "manifest_version": 3,
  "name": "Bookmarks",
  "version": "1.0",
  "description": "A simple bookmark manager designed for speed and simplicity",
  "icons": {
    "16": "favicon-16.png",
    "48": "favicon-48.png",
    "128": "favicon-128.png"
  },
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "favicon",
    "notifications",
    "pageCapture",
    "identity",
    "identity.email"
  ],
  "host_permissions": ["<all_urls>", "https://www.googleapis.com/*"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "oauth2": {
    "client_id": "{EXTENSION_OAUTH_CLIENT_ID}.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.appdata"]
  }
}
